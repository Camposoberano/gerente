# .env — Variáveis de ambiente do time de agentes
# Copie este arquivo para .env e preencha com seus dados

# Chave da API Anthropic (obrigatório)
# Acesse: https://console.anthropic.com/
ANTHROPIC_API_KEY=sua_chave_aqui

# Opcional: configurações extras
# NODE_ENV=development
# GEMINI_API_KEY=sua_chave_aqui
# GITHUB_API_URL=https://api.github.com
# GITHUB_TOKEN=github_pat_xxxxxxxxx
# GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/

# Opcional: revisão observável com @sentry (somente leitura)
# SENTRY_MCP_URL=https://mcp.sentry.dev/mcp
# SENTRY_AUTH_TOKEN=seu_token_readonly
# SENTRY_ORG=seu-org
# SENTRY_PROJECT=seu-projeto
# SENTRY_BASE_URL=https://sentry.io

# Dashboard local do gerente
# GERENTE_DASHBOARD_HOST=127.0.0.1
# GERENTE_DASHBOARD_PORT=8787

# Notificacao generica por webhook HTTP
# NOTIFY_WEBHOOK_URL=https://seu-webhook.exemplo/gerente
# NOTIFY_WEBHOOK_TOKEN=token_opcional

# WhatsApp Go / Uazapi para notificacoes
# O envio usa POST {WHATSAPP_GO_URL}/send/text com header token=<WHATSAPP_GO_INSTANCE_TOKEN>
# WHATSAPP_GO_URL=https://sua-uazapi.exemplo
# WHATSAPP_GO_INSTANCE_TOKEN=token_da_instancia
# WHATSAPP_NOTIFY_TO=5585999999999
# UAZAPI_URL=https://sua-uazapi.exemplo
# UAZAPI_INSTANCE_TOKEN=token_da_instancia
# GERENTE_WHATSAPP_GROUP_NAME=Gerente IA
# GERENTE_WHATSAPP_GROUP_PARTICIPANTS=5585999999999
# GERENTE_WHATSAPP_GROUP_JID=

# Coolify API / MCP
# COOLIFY_API_URL=https://seu-coolify.exemplo
# COOLIFY_API_TOKEN=token_api_coolify
# COOLIFY_MCP_URL=

# Portainer API / MCP
# PORTAINER_API_URL=https://seu-portainer.exemplo
# PORTAINER_API_TOKEN=ptr_xxxxxxxxx
# PORTAINER_MCP_URL=
# PORTAINER_MCP_AUTH_TOKEN=

# Firecrawl API / MCP
# FIRECRAWL_API_URL=https://api.firecrawl.dev
# FIRECRAWL_API_KEY=fc_xxxxxxxxx
# FIRECRAWL_API_KEY_BACKUP=fc_xxxxxxxxx
# FIRECRAWL_MCP_URL=

# Jina Reader API / MCP
# JINA_READER_URL=https://r.jina.ai/
# JINA_API_KEY=jina_xxxxxxxxx
# JINA_MCP_URL=

# Context7 MCP para documentacao atualizada de bibliotecas/APIs
# CONTEXT7_MCP_URL=https://mcp.context7.com/mcp
# CONTEXT7_API_KEY=ctx7_xxxxxxxxx

# Gerente MCP local
# command: node
# args: ["mcp/gerente-server.js"]

# Webhook publico do gerente para WhatsApp/Uazapi
# GERENTE_PUBLIC_BASE=https://gerente.seudominio.com
# GERENTE_WEBHOOK_TOKEN=token_aleatorio_para_querystring

# Cloudflare MCP oficial remoto
# CLOUDFLARE_MCP_URL=https://mcp.cloudflare.com/mcp

# Playwright MCP
# Modo stdio recomendado no cliente MCP: npx @playwright/mcp@latest
# Modo HTTP opcional:
# PLAYWRIGHT_MCP_URL=http://localhost:8931/mcp
# WHATSAPP_NOTIFY_DELAY=0
